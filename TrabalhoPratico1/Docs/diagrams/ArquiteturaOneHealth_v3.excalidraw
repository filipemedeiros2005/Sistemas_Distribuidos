    {
      "id": "M16Lj_ypy-FzbSDRHWBe-",
      "type": "text",
      "x": -1260.4665704342353,
      "y": -3403.6685609209167,
      "width": 2362.34326171875,
      "height": 103.84430435045267,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "ab",
      "roundness": null,
      "seed": 859365905,
      "version": 2357,
      "versionNonce": 1299134719,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1776210440397,
      "link": null,
      "locked": false,
      "text": "A arquitetura prevê a coexistência de múltiplos Gateways independentes, adotando uma topologia em estrela hierárquica. Cada Gateway atua como um agregador multiplexado, \nmantendo uma ligação persistente com o Servidor Central. Esta estrutura otimiza o tráfego da rede core, distribui a carga de processamento e isola falhas, \ngarantindo que a queda de um nó não comprometa a integridade global do sistema.",
      "fontSize": 27.691814493454046,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "A arquitetura prevê a coexistência de múltiplos Gateways independentes, adotando uma topologia em estrela hierárquica. Cada Gateway atua como um agregador multiplexado, \nmantendo uma ligação persistente com o Servidor Central. Esta estrutura otimiza o tráfego da rede core, distribui a carga de processamento e isola falhas, \ngarantindo que a queda de um nó não comprometa a integridade global do sistema.",
      "autoResize": true,
      "lineHeight": 1.25
    },
