    {
      "id": "ZY4x9lPvns38E9ycbsIAj",
      "type": "text",
      "x": 4677.627007051795,
      "y": 473.34146028844737,
      "width": 2264.1991687174764,
      "height": 2222.7914186507924,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b2Y",
      "roundness": null,
      "seed": 696056113,
      "version": 2178,
      "versionNonce": 668206705,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1776272261909,
      "link": null,
      "locked": false,
      "text": "INICIAR Mutex \"Acesso_BD_Global\"\nCONECTAR à Base de Dados PostgreSQL\n\nFUNÇÃO ProcessarDadosRecebidos(pacote):\n    // 1. Tratamento de Mensagens de Estado (Novidade)\n    SE pacote.MsgType == 7:\n        TextoStatus = (pacote.Value == 0) ? \"OFFLINE\" : \"ONLINE\"\n        BLOQUEAR(Acesso_BD_Global):\n            // SEGURANÇA: Uso de Parâmetros para evitar SQL Injection\n            EXECUTAR_SQL_PARAMETRIZADO(\n                \"UPDATE sensores_estado SET status = @status WHERE sensor_id = @id\",\n                { \"@status\": TextoStatus, \"@id\": pacote.SensorID }\n            )\n        RETORNAR\n\n    // 2. Tratamento de Telemetria (Normal ou Alerta)\n    TipoTexto = TraduzirIdParaNome(pacote.DataType)\n    DataOriginal = ConverterUnixParaTimestamp(pacote.Timestamp)\n    \n    BLOQUEAR(Acesso_BD_Global):\n        TENTAR:\n            // SEGURANÇA: Inserção segura com parâmetros\n            SQL = \"INSERT INTO telemetria (sensor_id, tipo, valor, data_leitura, prioritario) \n                   VALUES (@id, @tipo, @valor, @dt, @prio)\"\n            \n            PARAMETROS = {\n                \"@id\": pacote.SensorID,\n                \"@tipo\": TipoTexto,\n                \"@valor\": pacote.Value,\n                \"@dt\": DataOriginal,\n                \"@prio\": (pacote.MsgType == 6)\n            }\n            \n            EXECUTAR_SQL_PARAMETRIZADO(SQL, PARAMETROS)\n            \n            SE pacote.MsgType == 6:\n                // Log de alerta rápido para o Dashboard\n                EXECUTAR_SQL_PARAMETRIZADO(\n                    \"INSERT INTO alertas_criticos (sensor_id, ts) VALUES (@id, AGORA())\",\n                    { \"@id\": pacote.SensorID }\n                )\n                \n        CAPTURAR ERROS:\n            LOGAR(\"Erro de integridade: \" + erro.Mensagem)\n        FINALMENTE:\n            LIBERTAR(Acesso_BD_Global)",
      "fontSize": 38.65724206349204,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "INICIAR Mutex \"Acesso_BD_Global\"\nCONECTAR à Base de Dados PostgreSQL\n\nFUNÇÃO ProcessarDadosRecebidos(pacote):\n    // 1. Tratamento de Mensagens de Estado (Novidade)\n    SE pacote.MsgType == 7:\n        TextoStatus = (pacote.Value == 0) ? \"OFFLINE\" : \"ONLINE\"\n        BLOQUEAR(Acesso_BD_Global):\n            // SEGURANÇA: Uso de Parâmetros para evitar SQL Injection\n            EXECUTAR_SQL_PARAMETRIZADO(\n                \"UPDATE sensores_estado SET status = @status WHERE sensor_id = @id\",\n                { \"@status\": TextoStatus, \"@id\": pacote.SensorID }\n            )\n        RETORNAR\n\n    // 2. Tratamento de Telemetria (Normal ou Alerta)\n    TipoTexto = TraduzirIdParaNome(pacote.DataType)\n    DataOriginal = ConverterUnixParaTimestamp(pacote.Timestamp)\n    \n    BLOQUEAR(Acesso_BD_Global):\n        TENTAR:\n            // SEGURANÇA: Inserção segura com parâmetros\n            SQL = \"INSERT INTO telemetria (sensor_id, tipo, valor, data_leitura, prioritario) \n                   VALUES (@id, @tipo, @valor, @dt, @prio)\"\n            \n            PARAMETROS = {\n                \"@id\": pacote.SensorID,\n                \"@tipo\": TipoTexto,\n                \"@valor\": pacote.Value,\n                \"@dt\": DataOriginal,\n                \"@prio\": (pacote.MsgType == 6)\n            }\n            \n            EXECUTAR_SQL_PARAMETRIZADO(SQL, PARAMETROS)\n            \n            SE pacote.MsgType == 6:\n                // Log de alerta rápido para o Dashboard\n                EXECUTAR_SQL_PARAMETRIZADO(\n                    \"INSERT INTO alertas_criticos (sensor_id, ts) VALUES (@id, AGORA())\",\n                    { \"@id\": pacote.SensorID }\n                )\n                \n        CAPTURAR ERROS:\n            LOGAR(\"Erro de integridade: \" + erro.Mensagem)\n        FINALMENTE:\n            LIBERTAR(Acesso_BD_Global)",
      "autoResize": false,
      "lineHeight": 1.25
    },
