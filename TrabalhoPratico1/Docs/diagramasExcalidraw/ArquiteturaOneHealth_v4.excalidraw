    {
      "id": "nTT3sF7JQ1SsRkqffLMuw",
      "type": "text",
      "x": 4684.286669505942,
      "y": 7950.297666327793,
      "width": 2264.1991687174764,
      "height": 1546.2896825396817,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b77",
