    },
    {
      "id": "NRSmiIMC5v_bJlY8T5S-r",
      "type": "text",
      "x": -51.952400278268215,
      "y": -989.0141016752976,
      "width": 93.01101025682927,
      "height": 36.572453986218655,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
