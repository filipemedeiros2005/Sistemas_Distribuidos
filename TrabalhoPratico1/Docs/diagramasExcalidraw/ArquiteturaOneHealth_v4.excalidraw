    {
      "id": "Usm8wSd0GVIheECJDhX1P",
      "type": "text",
      "x": 4674.833442724382,
      "y": 6901.016284793851,
      "width": 2264.1991687174764,
      "height": 531.5370783730156,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b73",
      "roundness": null,
      "seed": 497166099,
      "version": 2693,
      "versionNonce": 1170781043,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1776338319101,
      "link": null,
      "locked": false,
      "text": "FUNÇÃO ValidarIntegridade(arrayBytes20):\n    // Extrai o checksum que veio no pacote (últimos 4 bytes)\n    ChecksumRecebido = ExtrairUint32(arrayBytes20, offset: 16)\n    \n    // Calcula o checksum dos primeiros 16 bytes\n    ChecksumCalculado = CALCULAR_CRC32(arrayBytes20.SubArray(0, 16))\n    \n    SE ChecksumCalculado == ChecksumRecebido:\n        RETORNAR VERDADEIRO // Pacote íntegro\n    SENÃO:\n        RETORNAR FALSO // Descartar pacote e registar erro",
      "fontSize": 38.65724206349204,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "FUNÇÃO ValidarIntegridade(arrayBytes20):\n    // Extrai o checksum que veio no pacote (últimos 4 bytes)\n    ChecksumRecebido = ExtrairUint32(arrayBytes20, offset: 16)\n    \n    // Calcula o checksum dos primeiros 16 bytes\n    ChecksumCalculado = CALCULAR_CRC32(arrayBytes20.SubArray(0, 16))\n    \n    SE ChecksumCalculado == ChecksumRecebido:\n        RETORNAR VERDADEIRO // Pacote íntegro\n    SENÃO:\n        RETORNAR FALSO // Descartar pacote e registar erro",
      "autoResize": false,
      "lineHeight": 1.25
    },
