    {
      "id": "9m4O2KB8_jkrKacsFMx2N",
      "type": "text",
      "x": 3153.141636619323,
      "y": -3059.035380111876,
      "width": 366.5904236316837,
      "height": 99.42962000480114,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b5Z",
      "roundness": null,
      "seed": 830007391,
      "version": 1838,
      "versionNonce": 319573235,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1776336444601,
      "link": null,
      "locked": false,
      "text": "Permite ao Gateway saber \na que câmara corresponde o \nframe recebido por UDP.",
      "fontSize": 26.51456533461364,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Permite ao Gateway saber \na que câmara corresponde o \nframe recebido por UDP.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "XW9gFXDedROxlh42hysMF",
      "type": "text",
      "x": 3133.7621734504437,
      "y": -2924.3752042931833,
      "width": 410.15388705611235,
      "height": 132.5728266730682,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b5a",
      "roundness": null,
      "seed": 1813677183,
      "version": 1931,
      "versionNonce": 1484535443,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1776336444601,
      "link": null,
      "locked": false,
      "text": "Crucial para sincronizar o vídeo \ncom os gráficos de telemetria \n(ex: ver o fumo no momento \nexato do pico de PPM).",
      "fontSize": 26.51456533461364,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Crucial para sincronizar o vídeo \ncom os gráficos de telemetria \n(ex: ver o fumo no momento \nexato do pico de PPM).",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "sdwnf3YEDSgX9igY_6w1e",
      "type": "text",
      "x": 3129.983014608816,
      "y": -2760.6486098002188,
      "width": 412.99089481421396,
      "height": 132.5728266730682,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b5b",
      "roundness": null,
      "seed": 1953733791,
      "version": 2342,
      "versionNonce": 1736305715,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1776336444601,
      "link": null,
      "locked": false,
      "text": "Essencial no UDP. Permite ao \nGateway detetar pacotes \nperdidos ou fora de \nordem antes de gravar no disco.",
      "fontSize": 26.51456533461364,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Essencial no UDP. Permite ao \nGateway detetar pacotes \nperdidos ou fora de \nordem antes de gravar no disco.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "S1lDKm1pTeF19rCMpS4ol",
      "type": "text",
      "x": 3122.3077451584086,
      "y": -2588.975586488992,
      "width": 424.9493887106611,
      "height": 99.42962000480114,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b5c",
      "roundness": null,
      "seed": 506769599,
      "version": 2198,
      "versionNonce": 1140321747,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1776336444601,
      "link": null,
      "locked": false,
      "text": "Indica quantos bytes o Gateway\ndeve ler a seguir ao cabeçalho \npara obter a imagem correta.",
      "fontSize": 26.51456533461364,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Indica quantos bytes o Gateway \ndeve ler a seguir ao cabeçalho \npara obter a imagem correta.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "35MnnAx5T5dTRNAW8K1X5",
      "type": "text",
      "x": 2490.3686578853594,
      "y": -2399.758894391212,
      "width": 123.52354778861319,
      "height": 40.95608649182831,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
