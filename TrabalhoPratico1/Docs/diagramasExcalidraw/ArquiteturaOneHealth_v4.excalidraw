    {
      "id": "rQOGUzWj93qiiwDMIK_4d",
      "type": "text",
      "x": 3155.3557159931515,
      "y": -2447.563842408553,
      "width": 368.10173098208384,
      "height": 132.5728266730682,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b5j",
      "roundness": null,
      "seed": 379964831,
      "version": 2677,
      "versionNonce": 1256117523,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1776336444601,
      "link": null,
      "locked": false,
      "text": "Contém o conteúdo visual. \nEm sistemas contidos, pode \nser apenas uma imagem \ncomprimida (JPEG).",
      "fontSize": 26.51456533461364,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Contém o conteúdo visual. \nEm sistemas contidos, pode \nser apenas uma imagem \ncomprimida (JPEG).",
      "autoResize": true,
      "lineHeight": 1.25
    },
