    },
    {
      "id": "3wlaMJAeO__PQeSFaJf8V",
      "type": "text",
      "x": 1794.8928675384645,
      "y": 6538.396292563338,
      "width": 1513.063232421875,
      "height": 35,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b7Q",
      "roundness": null,
      "seed": 1544596504,
      "version": 3348,
      "versionNonce": 1775602968,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775399731097,
      "link": null,
      "locked": false,
      "text": "Especificações da etapa B do diagrama anterior, dividida em dois cenários consoante o resultado das medições",
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Especificações da etapa B do diagrama anterior, dividida em dois cenários consoante o resultado das medições",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "6znkFabzrgN9Ejz70GvDI",
      "type": "text",
      "x": 1502.2760549687082,
      "y": 7855.688424259773,
      "width": 2188.114501953125,
      "height": 245,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b7R",
      "roundness": null,
      "seed": 1140270872,
      "version": 1546,
      "versionNonce": 1665051676,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775484808791,
      "link": null,
      "locked": false,
      "text": "Os dados são registados pelo sensor e é calculado o desvio-padrão da medição. \nOs registos com medições normais são acumulados no buffer normal do sensor, transmitidos para um buffer maior do gateway que, por usa vez,\nenvia os dados para o servidor (em intervalos de tempo pré-selecionados). No entanto, caso uma medição apresente valores superioes à margem de erro definida \no registo é enviado automaticamente para o buffer (prioritário), que por sua vez é automaticamente enviado do sensor para o gateway e do gateway\npara o servidor, com uma notificação de alerta relativa à anomalia detetada, sempre em buffers específicos para registos urgentes.\nOs registos guardados no buffer normal também são enviados (por buffers diferentes, com categorias diferentes) para evitar perda de dados \ncaso o sensor seja danificado ou caso os dados sejam apagados da memória.",
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Os dados são registados pelo sensor e é calculado o desvio-padrão da medição. \nOs registos com medições normais são acumulados no buffer normal do sensor, transmitidos para um buffer maior do gateway que, por usa vez,\nenvia os dados para o servidor (em intervalos de tempo pré-selecionados). No entanto, caso uma medição apresente valores superioes à margem de erro definida \no registo é enviado automaticamente para o buffer (prioritário), que por sua vez é automaticamente enviado do sensor para o gateway e do gateway\npara o servidor, com uma notificação de alerta relativa à anomalia detetada, sempre em buffers específicos para registos urgentes.\nOs registos guardados no buffer normal também são enviados (por buffers diferentes, com categorias diferentes) para evitar perda de dados \ncaso o sensor seja danificado ou caso os dados sejam apagados da memória.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "L7oy_Gc3H70j08VhBibpl",
      "type": "text",
      "x": 1586.7222524784731,
      "y": 7286.604620299045,
      "width": 345.6032453264508,
      "height": 280.02715462474464,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b7S",
      "roundness": null,
      "seed": 31167256,
      "version": 3537,
      "versionNonce": 2109915160,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775403507416,
      "link": null,
      "locked": false,
      "text": "Detetada Anomalia\n(V.A. > 3σ, por ex.)\nRegisto enviado\nautomaticamente\npara o buffer\nprioritário",
      "fontSize": 37.336953949965945,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Detetada Anomalia \n(V.A. > 3σ, por ex.)\nRegisto enviado\nautomaticamente\npara o buffer\nprioritário",
      "autoResize": false,
      "lineHeight": 1.25
    },
