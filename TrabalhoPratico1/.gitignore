# macOS
.DS_Store

# .NET build outputs
**/bin/
**/obj/
*.user
*.suo

# IDE / Editor caches
**/.idea/
**/.vs/
**/.vscode/

# Runtime media (regenerated by the system at runtime)
data/server_live/*.raw
data/videos/*.raw

# Log files (regenerated at runtime)
data/server_logs/*.log

# Python
**/__pycache__/
*.pyc
.venv/
*.egg-info/

# Go
*.exe
*.test
*.out
src/services/preprocessor-go/bin/

# gRPC generated files (regenerated from .proto)
src/services/analysis-py/onehealth_pb2.py
src/services/analysis-py/onehealth_pb2_grpc.py
