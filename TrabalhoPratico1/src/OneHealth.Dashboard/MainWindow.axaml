<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="using:OneHealth.Dashboard"
        xmlns:lvc="using:LiveChartsCore.SkiaSharpView.Avalonia"
        x:Class="OneHealth.Dashboard.MainWindow"
        x:DataType="local:MainWindow"
        Title="One Health - Command Center" Width="1100" Height="700" Background="#121212">
    
    <StackPanel Margin="20" Spacing="10">
        <TextBlock Text="One Health - Gestao Urbana" FontSize="26" FontWeight="Bold" Foreground="#3498db"/>
        
        <StackPanel Orientation="Horizontal" Spacing="20" Margin="0,0,0,10">
            <TextBlock Name="TxtGatewayStats" Foreground="#f1c40f" FontSize="14" FontWeight="Bold"/>
            <TextBlock Name="TxtServerStats" Foreground="#e67e22" FontSize="14" FontWeight="Bold"/>
        </StackPanel>

        <TabControl Background="#1e1e1e" Height="550">
            <TabItem Header="Sensores (Estado)">
                <ListBox Name="LstSensors" Background="#1e1e1e" Foreground="White" FontSize="18"/>
            </TabItem>
            
            <TabItem Header="Telemetria Real-Time">
                <ScrollViewer>
                    <ListBox Name="LstTelemetry" Background="#1e1e1e" Foreground="#3498db" FontSize="14"/>
                </ScrollViewer>
            </TabItem>
            
            <TabItem Header="Incidentes (Anomalias)">
                <ScrollViewer>
                    <ListBox Name="LstAlerts" Background="#1e1e1e">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="local:AlertaItem">
                                <StackPanel Orientation="Horizontal" Spacing="15" Margin="0,5">
                                    <TextBlock Text="{Binding Texto}" Foreground="#e74c3c" FontSize="16" VerticalAlignment="Center" Width="600"/>
                                    <Button Content="Ver Video" Click="BtnVerVideo_Click" Background="#c0392b" Foreground="White" Padding="10,5"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Análises">
                <Grid Margin="10" RowDefinitions="Auto,Auto,*" RowSpacing="10">
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="Tipo:" Foreground="White" VerticalAlignment="Center"/>
                        <ComboBox Name="CmbKind" SelectedIndex="0" Width="160">
                            <ComboBoxItem Content="AVG"/>
                            <ComboBoxItem Content="STDDEV"/>
                            <ComboBoxItem Content="ANOMALY_RATE"/>
                            <ComboBoxItem Content="FORECAST"/>
                        </ComboBox>
                        <TextBlock Text="Janela:" Foreground="White" VerticalAlignment="Center" Margin="20,0,0,0"/>
                        <ComboBox Name="CmbWindow" SelectedIndex="1" Width="100">
                            <ComboBoxItem Content="1m"/>
                            <ComboBoxItem Content="5m"/>
                            <ComboBoxItem Content="15m"/>
                            <ComboBoxItem Content="1h"/>
                        </ComboBox>
                        <Button Name="BtnRunAnalysis" Content="Executar Análise" Click="BtnRunAnalysis_Click"
                                Background="#3498db" Foreground="White" Padding="12,6"/>
                        <TextBlock Name="TxtAnalysisStatus" Foreground="#f1c40f" VerticalAlignment="Center" Margin="20,0,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="Zona:" Foreground="White" VerticalAlignment="Center"/>
                        <ComboBox Name="CmbZona" SelectedIndex="0" Width="170">
                            <ComboBoxItem Content="(todas)"/>
                            <ComboBoxItem Content="ZONA_NORTE"/>
                            <ComboBoxItem Content="ZONA_SUL"/>
                            <ComboBoxItem Content="ZONA_CENTRO"/>
                            <ComboBoxItem Content="ZONA_INDUSTRIAL"/>
                            <ComboBoxItem Content="ZONA_ESPECIAL"/>
                        </ComboBox>
                        <TextBlock Text="Tipos:" Foreground="White" VerticalAlignment="Center" Margin="15,0,0,0"/>
                        <CheckBox Name="ChkTEMP"  Content="TEMP"  Foreground="White"/>
                        <CheckBox Name="ChkHUM"   Content="HUM"   Foreground="White"/>
                        <CheckBox Name="ChkPM25"  Content="PM25"  Foreground="White"/>
                        <CheckBox Name="ChkPM10"  Content="PM10"  Foreground="White"/>
                        <CheckBox Name="ChkRUIDO" Content="RUIDO" Foreground="White"/>
                        <CheckBox Name="ChkLUM"   Content="LUM"   Foreground="White"/>
                        <TextBlock Text="Sensores:" Foreground="White" VerticalAlignment="Center" Margin="15,0,0,0"/>
                        <TextBox Name="TxtSensors" Width="120" PlaceholderText="101,102"/>
                    </StackPanel>
                    <Grid Grid.Row="2" ColumnDefinitions="380,*">
                        <ScrollViewer Grid.Column="0">
                            <ListBox Name="LstAnalyses" SelectionChanged="LstAnalyses_SelectionChanged"
                                     Background="#1e1e1e" Foreground="White" FontSize="13">
                                <ListBox.ItemTemplate>
                                    <DataTemplate x:DataType="local:AnaliseItem">
                                        <TextBlock Text="{Binding Display}" Margin="5,3" TextWrapping="Wrap"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </ScrollViewer>
                        <lvc:CartesianChart Grid.Column="1" Name="ChartAnalysis" Margin="10,0,0,0"
                                            Series="{Binding ChartSeriesData}"
                                            XAxes="{Binding ChartXAxes}"/>
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>
    </StackPanel>
</Window>