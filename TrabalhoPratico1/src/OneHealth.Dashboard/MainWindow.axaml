<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="OneHealth.Dashboard.MainWindow"
        Title="One Health - Edge Command Center" 
        Width="900" Height="650"
        Background="#121212">
    
    <StackPanel Margin="20" Spacing="10">
        <TextBlock Text="🌍 One Health - Centro de Monitorização" FontSize="26" FontWeight="Bold" Foreground="#3498db"/>
        
        <StackPanel Orientation="Horizontal" Spacing="20" Margin="0,0,0,10">
            <TextBlock Text="Sincronização em tempo real (1s) com PostgreSQL | Gateways de Borda Ativos" 
                       Foreground="#aaaaaa" VerticalAlignment="Center"/>
            
            <Button Name="BtnStream" Content="📹 Ver Feed de Vídeo (CCTV)" 
                    Background="#c0392b" Foreground="White" Padding="10,5"/>
        </StackPanel>
        
        <TabControl Background="#1e1e1e" Height="500">
            <TabItem Header="Estado dos Sensores" Foreground="White" FontSize="16">
                <ListBox Name="LstSensors" Background="#1e1e1e" Foreground="White" FontSize="18" Padding="10" CornerRadius="5"/>
            </TabItem>
            <TabItem Header="Registo de Anomalias" Foreground="White" FontSize="16">
                <ListBox Name="LstAlerts" Background="#1e1e1e" Foreground="#e74c3c" FontSize="16" Padding="10" CornerRadius="5"/>
            </TabItem>
        </TabControl>
    </StackPanel>
</Window>