<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="OneHealth.Dashboard.MainWindow"
        Title="One Health - Command Center" Width="950" Height="700" Background="#121212">
    <StackPanel Margin="20" Spacing="10">
        <TextBlock Text="🌍 One Health - Gestão Urbana" FontSize="26" FontWeight="Bold" Foreground="#3498db"/>
        <TabControl Background="#1e1e1e" Height="550">
            <TabItem Header="Sensores (Estado)">
                <ListBox Name="LstSensors" Background="#1e1e1e" Foreground="White" FontSize="18"/>
            </TabItem>
            <TabItem Header="Telemetria Real-Time">
                <ListBox Name="LstTelemetry" Background="#1e1e1e" Foreground="#3498db" FontSize="14"/>
            </TabItem>
            <TabItem Header="Incidentes &amp; Vídeo">
                <StackPanel Spacing="10">
                    <TextBlock Name="TxtVideoStats" Text="Aguardando anomalias..." Foreground="#e67e22" FontSize="16" Margin="10"/>
                    <ListBox Name="LstAlerts" Height="350" Background="#1e1e1e" Foreground="#e74c3c"/>
                    <Button Name="BtnStream" Content="📹 Abrir Player de Vídeo (Análise de Incidente)" HorizontalAlignment="Center" Background="#c0392b" Foreground="White" Padding="15,10"/>
                </StackPanel>
            </TabItem>
        </TabControl>
    </StackPanel>
</Window>